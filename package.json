{
  "name": "ignis-test-agent",
  "version": "2.0.0",
  "description": "IGNIS Automation Test Agent — AI-powered automation testing with backend validation, best practices enforcement, and comprehensive reporting",
  "main": "src/index.js",
  "bin": {
    "ignis": "src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node src/cli.js",
    "preflight": "node scripts/preflight-check.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/",
    "dev": "node --watch src/index.js",
    "validate": "node scripts/validate-setup.js",
    "setup": "npm install && npx playwright install chromium --with-deps",
    "test:local": "node scripts/preflight-check.js && node src/cli.js",
    "build:production": "node scripts/build-production.js",
    "docker:build": "docker build -t ignis-test-agent:latest .",
    "docker:diagnose": "docker run --rm ignis-test-agent:latest node scripts/diagnose-container.js"
  },
  "keywords": [
    "automation",
    "testing",
    "playwright",
    "ai",
    "github-actions",
    "ignis"
  ],
  "author": "IGNIS",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "openai": "^4.85.4",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "playwright": "1.50.0",
    "sequelize": "^6.37.5",
    "simple-git": "^3.27.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.21.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
