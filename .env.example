# ═══════════════════════════════════════════════════════════════════
# IGNIS Automation Test Agent — Local Testing Configuration
# ═══════════════════════════════════════════════════════════════════
#
# QUICK START FOR LOCAL TESTING:
# 1. Copy this file: cp .env.example .env
# 2. Add your API keys below
# 3. Run: npm install
# 4. Run: npm run cli
#
# For testing on a different project:
# - Set REPO_PATH to your project's directory
# - Or place your project files in the workspace/ folder
#
# ═══════════════════════════════════════════════════════════════════

# ── Server (API mode only - skip for CLI testing) ─────────────────
PORT=4000

# ── GitHub Authentication ──────────────────────────────────────────
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: GitHub App (for organizations)
# GITHUB_AUTH_METHOD=app
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_INSTALLATION_ID=789012

# ── AI Provider ────────────────────────────────────────────────────
# Choose ONE provider (openai recommended for local testing)
AI_PROVIDER=openai

# Universal API key (use this OR provider-specific key below)
# AI_API_KEY=your_api_key

# OpenAI (Recommended - Get key from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o  # Optional: gpt-4o (faster) or gpt-4-turbo (default)

# Google Gemini (Most Cost-Effective - Get key from: https://makersuite.google.com/app/apikey)
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-1.5-pro  # Optional

# Anthropic Claude (Premium - Get key from: https://console.anthropic.com/)
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514  # Optional

# ── Database (API mode only, optional) ────
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ignis_agent
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# ── Agent Configuration ────────────────────────────────────────────
# How many times to retry fixing failing tests
MAX_ITERATIONS=3

# Test types to generate (comma-separated)
# Options: e2e, api, visual, accessibility, performance
TEST_TYPES=e2e,api,accessibility

# Git branch configuration
REPO_BRANCH=main
FIX_BRANCH_PREFIX=ignis/fix

# Validation and reporting
ANALYSIS_PROMPT_FILE=config/analysis-prompts.json
ENABLE_BACKEND_VALIDATION=true
ENABLE_BEST_PRACTICES_CHECK=true
ENABLE_ENDPOINT_VALIDATION=true
GENERATE_ANALYSIS_REPORT=true
REPORT_OUTPUT_DIR=reports

# ── Target Application (Project to Test) ──────────────────────────
# Point to your project directory for local testing
# REPO_PATH=D:/path/to/your/project

# If your app is already running, provide the URL:
# APP_URL=http://localhost:3000

# Auto-start the application (recommended for local testing)
AUTO_START_APP=true

# Custom start command (auto-detected if not set)
# APP_START_COMMAND=npm start
# APP_START_COMMAND=npm run dev
# APP_START_COMMAND=python manage.py runserver
# APP_START_COMMAND=php artisan serve

# Expected port (auto-detected if not set)
# APP_PORT=3000

# Environment variables needed by YOUR application
# APP_SECRETS={"DATABASE_URL":"postgresql://user:pass@localhost:5432/mydb","JWT_SECRET":"secret123"}

# ── Logging ──────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
