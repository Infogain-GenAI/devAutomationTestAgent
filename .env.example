# ═══════════════════════════════════════════
# IGNIS Automation Test Agent — Configuration
# ═══════════════════════════════════════════

# ── Server (API mode) ─────────────────────
PORT=4000

# ── GitHub Authentication ─────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_AUTH_METHOD=app
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_INSTALLATION_ID=789012

# ── AI Provider ───────────────────────────
# Choose ONE provider (openai recommended, claude and gemini also supported)
AI_PROVIDER=openai

# Set ONE of these (or use AI_API_KEY as a universal key):
# AI_API_KEY=your_api_key

# OpenAI (Recommended - Best balance of quality and cost)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o  # Optional: override default (gpt-4-turbo)

# Google Gemini (Most Cost-Effective)
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-1.5-pro  # Optional

# Anthropic Claude (Premium Quality)
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514  # Optional

# ── Database (API mode only, optional) ────
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ignis_agent
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# ── Agent Configuration ──────────────────
MAX_ITERATIONS=3
TEST_TYPES=e2e,api,visual,accessibility,performance
REPO_BRANCH=main
FIX_BRANCH_PREFIX=ignis/fix
ANALYSIS_PROMPT_FILE=config/analysis-prompts.json
ENABLE_BACKEND_VALIDATION=true
ENABLE_BEST_PRACTICES_CHECK=true
ENABLE_ENDPOINT_VALIDATION=true
GENERATE_ANALYSIS_REPORT=true
REPORT_OUTPUT_DIR=reports

# ── Target Application ───────────────────
# APP_URL=http://localhost:3000
AUTO_START_APP=true
# APP_START_COMMAND=npm start
# APP_PORT=3000
# APP_SECRETS={"DATABASE_URL":"postgresql://user:pass@db:5432/myapp","JWT_SECRET":"secret"}

# ── Logging ──────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
